    "formdata-node": "^6.0.3",
    "next": "^16.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-markdown": "^9.1.0",
    "sharp": "^0.34.1",
    "tinacms": "^3.8.3",
    "tw-elements": "1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tinacms/cli": "^2.4.1",
    "autoprefixer": "^10.4.20",
    "babel-plugin-styled-components": "^2.1.4",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
